---
import HomePage from "../../pages/home-page.astro";
import { defaultLocale, locales, homeByLocale } from "../../i18n/locales";
import type { Locale } from "../../i18n/types";

export function getStaticPaths() {
    return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

const locale: Locale = locales.includes(lang as Locale)
    ? (lang as Locale)
    : defaultLocale;
const data = homeByLocale[locale];
---

<HomePage locale={locale} data={data} />
